{
  "name": "nexus-launcher",
  "version": "1.3.1-beta",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build:ahk": "chcp 65001 > nul && \"C:\\Program Files\\AutoHotkey\\Compiler\\Ahk2Exe.exe\" /in .ahk/nexus_trigger.ahk /out assets\\nexus_trigger.exe",
    "clean": "rimraf dist out",
    "build": "npm run clean && npm run build:ahk && electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "description": "Context-triggered action launcher for Windows. Dispatch selected text to any URL, file, script, or command via an unlimited provider library.",
  "author": "Nexus Launcher",
  "homepage": "https://github.com/wsnh2022/nexus-launcher",
  "devDependencies": {
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "electron-vite": "^5.0.0",
    "rimraf": "^6.1.2",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.nexuslauncher.app",
    "productName": "Nexus Launcher",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexus Launcher"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.3"
  }
}
